{
  "name": "public-bingo",
  "version": "0.1.0",
  "private": true,
  "description": "A real-time multiplayer bingo web application",
  "main": "index.js",
  "scripts": {
    "start": "webpack serve --config webpack.config.js --mode development",
    "build": "webpack --config webpack.config.js --mode production",
    "build:analyze": "webpack --config webpack.config.js --mode production --env analyze",
    "dev": "webpack serve --config webpack.config.js --mode development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:gameplay": "node src/tests/runGameplayTests.js",
    "test:gameplay:watch": "node src/tests/runGameplayTests.js --watch",
    "test:gameplay:logic": "node src/tests/runGameplayTests.js --category 'Game Logic'",
    "test:gameplay:components": "node src/tests/runGameplayTests.js --category 'Component Testing'",
    "test:gameplay:integration": "node src/tests/runGameplayTests.js --category 'Integration Testing'",
    "test:coverage": "jest --coverage",
    "test:coverage:gameplay": "jest --coverage --testPathPattern=src/tests/",
    "eject": "react-scripts eject",
    "create-admin": "node src/scripts/createAdmin.js",
    "deploy-rules": "firebase deploy --only firestore:rules",
    "firebase-login": "firebase login",
    "firebase-init": "firebase init",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "set-admin": "ts-node src/admin-scripts/setAdminClaims.ts",
    "build:prod": "cross-env NODE_ENV=production webpack --config webpack.config.js --mode production",
    "analyze": "cross-env ANALYZE=true npm run build:prod",
    "performance:report": "npm run build:analyze && open bundle-report.html",
    "performance:monitor": "cross-env PERFORMANCE_MONITOR=true npm start"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/socket.io-client": "^1.4.36",
    "firebase": "^9.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "react-scripts": "^5.0.1",
    "socket.io-client": "^4.8.1"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@babel/preset-env": "^7.28.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/dotenv": "^8.2.0",
    "@types/firebase": "^2.4.32",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/react-router-dom": "^5.3.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "babel-loader": "^10.0.0",
    "buffer": "^6.0.3",
    "clean-webpack-plugin": "^4.0.0",
    "compression-webpack-plugin": "^10.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "dotenv": "^16.6.1",
    "dotenv-cli": "^8.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-react": "^7.37.5",
    "firebase-admin": "^13.2.0",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mini-css-extract-plugin": "^2.9.2",
    "process": "^0.11.10",
    "react-app-rewired": "^2.2.1",
    "style-loader": "^3.3.3",
    "terser-webpack-plugin": "^5.3.14",
    "ts-jest": "^29.3.2",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5",
    "util": "^0.12.5",
    "webpack": "^5.99.5",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "webpack-merge": "^5.10.0"
  }
}
