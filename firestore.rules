rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.admin == true || 
         request.auth.token.firebase.sign_in_provider == 'google-service-account');
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Game rules
    match /games/{gameId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        // Allow users to update game data for multiplayer
        request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['markedPhrases', 'players', 'participants', 'status', 'gameStartedAt']) ||
        // Allow admins full access
        isAdmin()
      );
      allow delete: if isAdmin();
      
      // Board rules (subcollection)
      match /boards/{boardId} {
        allow read: if true;
        // Users can only create/update their own boards
        allow create: if isAuthenticated() && 
          request.resource.data.userId == request.auth.uid;
        allow update: if isAuthenticated() && 
          resource.data.userId == request.auth.uid &&
          // Only allow marking/unmarking cells
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['cells', 'hasWon', 'updatedAt']);
        // Only admins can delete boards
        allow delete: if isAdmin();
      }
    }

    // User rules
    match /users/{userId} {
      allow read: if true;
      // Users can only update their own profile
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      
      // Validate user data on write
      allow write: if (isOwner(userId) || isAdmin()) && 
        request.resource.data.keys().hasAll(['displayName', 'email']) &&
        request.resource.data.displayName is string &&
        request.resource.data.email is string;
    }

    // Game stats rules
    match /gameStats/{statId} {
      allow read: if true;
      // Only authenticated users can update stats
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }
  }
}